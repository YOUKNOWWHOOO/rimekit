{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rimekit.local/shared/spec/sync_manifest.schema.json",
  "title": "SyncManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_id",
    "config_payload",
    "resource_payloads",
    "user_data_payloads",
    "platform_targets",
    "delivery_plan",
    "success_criteria",
    "consistency_hashes"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "config_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config_version",
        "payload_path",
        "sha256"
      ],
      "properties": {
        "config_version": {
          "type": "integer",
          "const": 1
        },
        "payload_path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resource_payloads": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/payload_ref"
      }
    },
    "user_data_payloads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/payload_ref"
      }
    },
    "platform_targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "android",
        "windows"
      ],
      "properties": {
        "android": {
          "$ref": "#/$defs/platform_target"
        },
        "windows": {
          "$ref": "#/$defs/platform_target"
        }
      }
    },
    "delivery_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform",
          "phase",
          "task_id",
          "manual_required"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "enum": [
              "android",
              "windows",
              "cross_platform"
            ]
          },
          "phase": {
            "type": "string",
            "enum": [
              "detect",
              "configure",
              "generate",
              "backup",
              "apply",
              "deploy",
              "recheck",
              "rollback",
              "diagnose"
            ]
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "manual_required": {
            "type": "boolean"
          }
        }
      }
    },
    "success_criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config_model",
        "formal_resource",
        "user_data",
        "target_config",
        "runtime_state"
      ],
      "properties": {
        "config_model": {
          "$ref": "#/$defs/success_rule"
        },
        "formal_resource": {
          "$ref": "#/$defs/success_rule"
        },
        "user_data": {
          "$ref": "#/$defs/success_rule"
        },
        "target_config": {
          "$ref": "#/$defs/success_rule"
        },
        "runtime_state": {
          "$ref": "#/$defs/success_rule"
        }
      }
    },
    "consistency_hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "payload_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payload_id",
        "payload_kind",
        "path",
        "sha256"
      ],
      "properties": {
        "payload_id": {
          "type": "string",
          "minLength": 1
        },
        "payload_kind": {
          "type": "string",
          "enum": [
            "schema",
            "dictionary",
            "model",
            "template",
            "preset",
            "custom_entries",
            "user_dict_export"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "platform_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files",
        "success_checks"
      ],
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "success_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "success_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "comparison_basis"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "comparison_basis": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
