{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rimekit.local/shared/spec/backup_manifest.schema.json",
  "title": "BackupManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "backup_id",
    "created_at",
    "platform",
    "snapshot_id",
    "platform_targets",
    "resource_state",
    "snapshot_ref",
    "restorable"
  ],
  "properties": {
    "backup_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "platform": {
      "type": "string",
      "enum": [
        "android",
        "windows",
        "cross_platform"
      ]
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "platform_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "resource_state": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "restorable": {
      "type": "boolean"
    },
    "includes_user_data": {
      "type": "boolean"
    }
  }
}
